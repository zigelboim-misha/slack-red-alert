# Required: Slack user OAuth token (xoxp-...)
# Create at https://api.slack.com/apps → OAuth & Permissions → User Token Scopes → users.profile:write
SLACK_TOKEN=xoxp-your-token-here

# Optional: Comma-separated city prefixes in Hebrew (default: Tel Aviv, Givatayim, Ramat Gan)
# ALERT_CITIES=תל אביב,גבעתיים,רמת גן

# Optional: Pipe-separated status messages — a random one is picked each alert
# Defaults to a built-in list of 7 messages if unset
# ALERT_STATUS_TEXTS=Red Alert - seeking shelter|BRB, dodging rockets|In the safe room, back soon

# Optional: Pikud HaOref polling interval in seconds (default: 10)
# POLL_INTERVAL_SECONDS=10
